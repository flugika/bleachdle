{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check-assets": "npx tsx src/scripts/check-assets.js",
    "extract-meta": "npx tsx src/scripts/extract-character-meta.js",
    "extract-character": "npx tsx src/scripts/extract-character.js",
    "generate-wallpapers": "npx tsx src/scripts/generate-wallpapers.js",
    "seed:characters": "npx tsx --env-file=.env src/scripts/seeds/daily/seed-characters.js",
    "seed:songs": "npx tsx --env-file=.env src/scripts/seeds/daily/seed-songs.js",
    "seed:trigger-schedule": "npx tsx --env-file=.env src/scripts/seeds/trigger-schedule.js",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@supabase/supabase-js": "^2.110.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "framer-motion": "^12.42.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
}